# =============================================================================
# .env.example - Template Environment Variables ICICoS 2026 RAG Bot
#
# CARA PENGGUNAAN:
#   1. Salin file ini: cp .env.example .env
#   2. Isi semua nilai yang ditandai dengan <...>
#   3. JANGAN commit file .env ke Git!
# =============================================================================

# --- Telegram Bot ---
# Dapatkan token dari @BotFather di Telegram
TELEGRAM_BOT_TOKEN=<your_telegram_bot_token>

# ---------------------------------------------------------------------------
# LLM Provider — pilih salah satu: "openrouter" | "gemini" | "ollama"
# ---------------------------------------------------------------------------
LLM_PROVIDER=gemini

# --- OpenRouter (https://openrouter.ai/keys) ---
OPENROUTER_API_KEY=<your_openrouter_api_key>
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# --- Google Gemini (https://aistudio.google.com/apikey) ---
# Dipakai untuk: (1) LLM generator jawaban, (2) konversi PDF BPMN → teks saat ingesti
GEMINI_API_KEY=<your_gemini_api_key>
GEMINI_MODEL=gemini-2.0-flash

# Model ringan/cepat untuk Agentic Nodes (Rewriter, Router, Verifier)
# Gunakan model Flash agar hemat kuota dan responsif
GEMINI_FAST_MODEL=gemini-2.0-flash

# Model yang digunakan khusus untuk ingesti dokumen (konversi diagram PDF)
GEMINI_MODELS=gemini-3.1-pro-preview

# --- Ollama (lokal, https://ollama.com) ---
# Jalankan Ollama terlebih dahulu: `ollama serve` dan `ollama pull <model>`
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=granite4.1:3b

# ---------------------------------------------------------------------------
# Database PostgreSQL
# Nilai ini digunakan oleh:
#   - docker-compose.yml (DB_USER, DB_PASSWORD, DB_NAME, DB_PORT)
#   - backend Python (DATABASE_URL)
# ---------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=icicos_admin
DB_PASSWORD=<your_db_password>
DB_NAME=icicos_db
# Sesuaikan credential di bawah ini dengan DB_USER, DB_PASSWORD, DB_HOST, DB_PORT, dan DB_NAME Anda
DATABASE_URL=postgresql+asyncpg://icicos_admin:<your_db_password>@localhost:5432/icicos_db

# --- pgAdmin 4 (akses via http://localhost:5050 setelah docker compose up) ---
PGADMIN_EMAIL=admin@icicos.org
PGADMIN_PASSWORD=<your_pgadmin_password>

# ---------------------------------------------------------------------------
# RAG / ChromaDB
# ---------------------------------------------------------------------------
CHROMA_PERSIST_DIR=./data/chroma_db
RETRIEVER_TOP_K=4
SIMILARITY_THRESHOLD=0.4
EXTRACTED_TEXT_DIR=./data/extracted_text
# Direktori penyimpanan Parent Document utuh (dipakai oleh ParentDocumentRetriever)
PARENT_STORE_DIR=./data/parent_store

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
